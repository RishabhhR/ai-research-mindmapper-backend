# ── LLM Providers ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here   # optional fallback

# ── Database ────────────────────────────────────────────────
# Option A: Turso (free hosted SQLite — recommended for deployment)
# 1. brew install tursodatabase/tap/turso
# 2. turso auth signup
# 3. turso db create mindmapper-db
# 4. turso db show mindmapper-db --url   → paste below
# 5. turso db tokens create mindmapper-db → paste below
TURSO_URL=libsql://mindmapper-db-<your-username>.turso.io
TURSO_AUTH_TOKEN=your_turso_token_here

# Option B: Local SQLite (default if TURSO_URL is not set)
# DATABASE_URL=sqlite:///./mindmapper.db
